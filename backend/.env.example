# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require

# ─── Python pipeline ──────────────────────────────────────────────────────────
PYTHON_BIN=python
